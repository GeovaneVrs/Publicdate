# --- API (pasta api) ---
PORT=3000
HOST=0.0.0.0
# Caminho absoluto do cache (opcional; padrão: ../data/cache relativo ao código)
DATA_CACHE_DIR=
# Origens CORS para o front React (CSV). Em dev a API já libera localhost:5173.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Web (pasta web, build de produção) ---
# URL pública da API (sem barra no final). Em dev o Vite usa proxy /api e não precisa.
# VITE_API_URL=https://api.exemplo.com
